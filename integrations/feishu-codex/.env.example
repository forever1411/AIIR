# 仅保存在本机私密配置中，不要提交真实值。
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=replace_me

# 首次私聊机器人时使用。建议至少 16 个随机字符。
FEISHU_PAIRING_CODE=replace_with_a_random_pairing_code

# 逗号分隔的飞书 open_id。可留空，首次用配对码绑定后会写入本机状态文件。
FEISHU_ALLOWED_OPEN_IDS=

# 群聊默认关闭。仅允许逗号分隔的 chat_id；即使允许，也只开放只读命令。
FEISHU_ALLOWED_GROUP_CHAT_IDS=

# 飞书桥与本机 Codex app-server 的连接。必须是本机回环 ws 地址。
CODEX_APP_SERVER_URL=ws://127.0.0.1:4500
AIIR_REPO_ROOT=/home/admin/AIIR

# 保持 read-only。需要改文件时，在飞书中使用 /aiir write 逐轮授权。
FEISHU_CODEX_SANDBOX=read-only

# 可选。默认写入 ~/.local/state/aiir-feishu-codex/state.json
# AIIR_FEISHU_STATE_PATH=/home/admin/.local/state/aiir-feishu-codex/state.json
