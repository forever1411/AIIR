# AIIR currently does not require an API key for the ChatGPT-first pilot.
# Future software experiments may use one provider at a time.

AIIR_ENV=development
AIIR_PRIVATE_DATA_DIR=workspace/private
AIIR_DATABASE_PATH=workspace/private/aiir.sqlite3

# Optional future provider credentials. Never commit real values.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
